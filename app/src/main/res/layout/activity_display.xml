<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activity_display_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper"> <!-- Replace with your background -->

    <!-- WiFi Icon -->
    <ImageView
        android:id="@+id/wifi_image"
        android:layout_width="57dp"
        android:layout_height="42dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/wifi" />

    <!-- Battery Icon -->
    <ImageView
        android:id="@+id/battery_image"
        android:layout_width="36dp"
        android:layout_height="44dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/battery" />

    <!-- Time TextView -->
    <TextView
        android:id="@+id/time_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:text="00:00"
        android:textSize="24sp"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

    <!-- Date TextView -->
    <TextView
        android:id="@+id/date_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/time_text_view"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="Mon, Jan 1"
        android:textSize="18sp"
        android:textColor="@android:color/white" />

    <!-- App Buttons -->

    <ImageButton
        android:id="@+id/browser_button"
        android:layout_width="107dp"
        android:layout_height="92dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="60dp"
        android:layout_marginBottom="36dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/calculator"
        android:src="@drawable/calculator" />

    <ImageButton
        android:id="@+id/phone_button"
        android:layout_width="105dp"
        android:layout_height="93dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="320dp"
        android:layout_marginBottom="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/phone"
        android:src="@drawable/phone" />

    <ImageButton
        android:id="@+id/messages_button"
        android:layout_width="109dp"
        android:layout_height="90dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="59dp"
        android:layout_marginBottom="146dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/messages"
        android:src="@drawable/messages" />

    <ImageButton
        android:id="@+id/contacts_button"
        android:layout_width="108dp"
        android:layout_height="95dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="194dp"
        android:layout_marginBottom="33dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/contacts"
        android:src="@drawable/contacts" />

    <ImageButton
        android:id="@+id/settings_button"
        android:layout_width="104dp"
        android:layout_height="85dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="186dp"
        android:layout_marginBottom="150dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/settings"
        android:src="@drawable/settings" />

    <ImageButton
        android:id="@+id/notes_button"
        android:layout_width="111dp"
        android:layout_height="90dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="310dp"
        android:layout_marginBottom="145dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/notes"
        android:src="@drawable/notes" />
</RelativeLayout>
