<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activity_display_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper">

    <ImageView
        android:id="@+id/wifi_image"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="24dp"
        android:layout_marginTop="22dp"
        android:scaleType="fitCenter"
        android:src="@drawable/wifi" />

    <ImageView
        android:id="@+id/battery_image"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="24dp"
        android:scaleType="fitCenter"
        android:src="@drawable/battery" />

    <TextView
        android:id="@+id/time_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="34dp"
        android:text="00:00"
        android:textColor="@android:color/white"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/date_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/time_text_view"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="Mon, Jan 1"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

    <GridLayout
        android:id="@+id/app_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="54dp"
        android:alignmentMode="alignMargins"
        android:columnCount="3"
        android:rowCount="2"
        android:useDefaultMargins="false">

        <ImageButton
            android:id="@+id/notes_button"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_marginBottom="26dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/notes"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/notes" />

        <ImageButton
            android:id="@+id/settings_button"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_marginBottom="26dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/settings"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/settings" />

        <ImageButton
            android:id="@+id/messages_button"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_marginBottom="26dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/messages"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/messages" />

        <ImageButton
            android:id="@+id/phone_button"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:contentDescription="@string/phone"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/phone" />

        <ImageButton
            android:id="@+id/contacts_button"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:contentDescription="@string/contacts"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/contacts" />

        <ImageButton
            android:id="@+id/browser_button"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:contentDescription="@string/calculator"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/calculator" />

    </GridLayout>

</RelativeLayout>
